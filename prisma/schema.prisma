// ============================================
// Prisma Schema - 主配置文件
// ============================================
//
// 📁 多文件 Schema 结构：
//    prisma/
//    ├── migrations/
//    ├── models/          ← 模型定义按领域分组
//    │   ├── auth.prisma
//    │   └── application.prisma
//    └── schema.prisma    ← generator + datasource (此文件)
//
// 💡 Prisma ORM v6+ 原生支持多文件 schema
//    所有 .prisma 文件中的模型可以互相引用，无需显式导入
//
// 📖 了解更多：https://pris.ly/d/multi-file-schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
